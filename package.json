{
    "name": "@openbook-studio/workspace",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "packageManager": "npm",
    "workspaces": [
        "src/frontend/*",
        "src/libraries/*"
    ],
    "scripts": {
        "redis": "redis-server",
        "runserver": "cd src && python manage.py runserver",
        "maildev": "maildev -s 1025 -w 8887",
        "frontend": "cd src/frontend && npm run watch",
        "libraries": "cd src/libraries && npm run watch",
        "start": "conc -n redis,django,fake-smtp,frontend,libraries -c auto \"npm run redis\" \"npm run runserver\" \"npm run maildev\" \"npm run frontend\" \"npm run libraries\"",
        "start:debug": "conc -n redis,fake-smtp,frontend,libraries -c auto \"npm run redis\" \"npm run maildev\" \"npm run frontend\" \"npm run libraries\"",
        "build:libraries": "cd src/libraries && npm run build",
        "build:frontend": "cd src/frontend && npm run build",
        "build": "npm run build:frontend && npm run build:libraries",
        "lint:frontend": "cd src/frontend && npm run lint",
        "lint:libraries": "cd src/libraries && npm run lint",
        "lint": "npm run lint:frontend && npm run lint:libraries",
        "fix:frontend-install": "rm -rf src/frontend/node_modules && npm install --legacy-peer-deps",
        "init:db": "cd src && python manage.py migrate && python manage.py load_initial_data && python manage.py install_html_library && python manage.py createsuperuser",
        "test:backend": "cd src && poetry run python manage.py test",
        "test": "npm run test:backend",
        "check": "npm run lint && npm run test"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/svelte": "^5.0.8",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "ajv": "^8.18.0",
        "conc": "^0.0.3",
        "concurrently": "^9.2.1",
        "esbuild": "^0.27.4",
        "esbuild-svelte": "^0.9.4",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "glob": "^13.0.6",
        "globals": "^17.4.0",
        "jszip": "^3.10.1",
        "maildev": "^2.2.1",
        "prettier": "^3.8.1",
        "shelljs": "^0.10.0",
        "sv": "^0.12.7",
        "svelte": "^5.53.12",
        "svelte-check": "^4.4.5",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "yaml": "^2.8.2"
    },
    "dependencies": {
        "eslint-plugin-unused-imports": "^4.4.1"
    }
}
