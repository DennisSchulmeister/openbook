{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:best-practices",
        ":dependencyDashboard",
        ":semanticCommits",
        ":semanticCommitTypeAll(chore)",
        ":automergeRequireAllStatusChecks",
        "helpers:pinGitHubActionDigests"
    ],
    "timezone": "Europe/Berlin",
    "dependencyDashboardTitle": "Dependency Dashboard",
    "enabledManagers": [
        "docker-compose",
        "dockerfile",
        "github-actions",
        "npm",
        "poetry"
    ],
    "labels": [
        "dependencies",
        "automated"
    ],
    "configMigration": true,
    "platformAutomerge": false,
    "prConcurrentLimit": 5,
    "prHourlyLimit": 2,
    "rebaseWhen": "behind-base-branch",
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": [
            "* 0-5 * * 1"
        ],
        "automerge": true,
        "addLabels": [
            "weekly-update"
        ]
    },
    "packageRules": [
        {
            "description": "Bump declared minimums for npm and Poetry dependencies instead of only refreshing lock files",
            "matchManagers": [
                "npm",
                "poetry"
            ],
            "rangeStrategy": "bump"
        },
        {
            "description": "Work around current npm peer dependency metadata issues in this repository",
            "matchManagers": [
                "npm"
            ],
            "postUpdateOptions": [
                "npmInstallTwice"
            ]
        },
        {
            "description": "Automerge weekly non-major dependency updates",
            "matchUpdateTypes": [
                "digest",
                "minor",
                "patch",
                "pin",
                "pinDigest"
            ],
            "schedule": [
                "* 0-5 * * 1"
            ],
            "automerge": true,
            "addLabels": [
                "weekly-update"
            ]
        },
        {
            "description": "Create monthly major update PRs for manual review",
            "matchUpdateTypes": [
                "major"
            ],
            "schedule": [
                "* 0-5 1 * *"
            ],
            "automerge": false,
            "addLabels": [
                "major-update",
                "manual-review"
            ],
            "prBodyNotes": [
                "Review the upstream migration notes before merging this major update."
            ]
        },
        {
            "description": "Track GitHub Actions updates as part of dependency maintenance",
            "matchManagers": [
                "github-actions"
            ],
            "dependencyDashboardCategory": "GitHub Actions",
            "commitMessageTopic": "GitHub Actions dependencies"
        },
        {
            "description": "Track Docker example image tags in the example deployment setup",
            "matchManagers": [
                "docker-compose",
                "dockerfile"
            ],
            "matchFileNames": [
                "_docker/**"
            ],
            "dependencyDashboardCategory": "Docker Example Setup"
        }
    ]
}